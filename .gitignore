# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# database (SQLite is local/dev only — Railway uses its own volume)
*.db
*.db-journal
*.db-wal
*.db-shm

# AI tooling artifacts (not needed to run or deploy the app)
.agents/
.claude/
skills-lock.json
AGENTS.md
CLAUDE.md

# brand reference screenshots (source material only, not used by the app)
/brand-reference

# playwright (only used ad-hoc for local QA, not part of the app)
/test-results/
/playwright-report/
/playwright/.cache/
